    cout << "Pocatecni pocet serveru: " << ServerNode::getPocetServeru() << "\n\n";

    cout << "--- Test algoritmu nad std::vector ---\n";
    KritickyServer k1("Sec-Master");
    k1.pridejZaznam(40.0);
    k1.pridejZaznam(40.0);
    k1.pridejZaznam(45.0);
    k1.pridejZaznam(90.0);
    k1.pridejZaznam(90.0);
    k1.pridejZaznam(50.0);
    k1.pridejZaznam(50.0);

    cout << "Pred deduplikaci: " << k1 << endl;
    odstranDuplicity(k1.getZatezCPU());
    cout << "Po deduplikaci:   " << k1 << endl;

    cout << "Detekce skoku (hranice 30%):" << endl;
    int nalezeno = detekujSkokyZateze(k1.getZatezCPU(), 30.0);
    cout << "Celkem detekovano skoku: " << nalezeno << "\n\n";


    cout << "--- Test operatoru + a klustrovani ---\n";
    KlustrovyServer* nodeX = new KlustrovyServer("Node-X");
    KlustrovyServer* nodeY = new KlustrovyServer("Node-Y");

    nodeX->pridejZaznam(20.0);
    nodeX->pridejZaznam(40.0);
    nodeX->pridejZaznam(60.0);

    nodeY->pridejZaznam(30.0);
    nodeY->pridejZaznam(50.0);

    // Záměrná chyba: nodeY má jen 2 záznamy, nodeX má 3. 
    // Místo try/catch program prostě vypíše chybu do konzole, protože jsme to tak naprogramovali.
    KlustrovyServer chybnyVysledek = *nodeX + *nodeY;
    
    // Doplníme záznam a zkusíme to znovu (teď už to projde v pořádku)
    nodeY->pridejZaznam(70.0);
    KlustrovyServer vyslednyKlustr = *nodeX + *nodeY;
    
    cout << "Pouziti operatoru + po oprave rozmeru:" << endl;
    cout << vyslednyKlustr << "\n\n";


    cout << "--- Uklid pameti ---\n";
    delete nodeX;
    delete nodeY;

    // Počítadlo bude 3, protože se nám na chvíli vytvořil i ten chybový prázdný objekt "chybnyVysledek"
    cout << "Konecny pocet serveru v evidenci: " << ServerNode::getPocetServeru() << endl;

    return 0;
}
