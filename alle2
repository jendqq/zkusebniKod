#include <iostream>
#include <vector>
#include <string>
#include <algorithm> 

using namespace std;

// ============================================================================
// 1. BÁZOVÁ TŘÍDA: ServerNode
// ============================================================================
class ServerNode {
private:
    string nazev;
    static int pocetServeru; 

protected:
    vector<double> zatezCPU;

public:
    ServerNode(const string& nazev) : nazev(nazev) {
        pocetServeru++;
    }
    
    virtual ~ServerNode() {
        pocetServeru--;
    }

    static int getPocetServeru() {
        return pocetServeru;
    }

    void pridejZaznam(double zatez) {
        zatezCPU.push_back(zatez);
    }
    
    const vector<double>& getZatezCPU() const { return zatezCPU; }
    vector<double>& getZatezCPU() { return zatezCPU; }

    string getNazev() const { return nazev; }

    virtual void diagnostika() = 0;

    friend ostream& operator<<(ostream& os, const ServerNode& node) {
        os << "[" << node.nazev << "] Historie: ";
        if (node.zatezCPU.empty()) {
            os << "Zadne zaznamy";
        } else {
            for (double zatez : node.zatezCPU) {
                os << zatez << "%, ";
            }
        }
        return os;
    }
};

int ServerNode::pocetServeru = 0;


// ============================================================================
// 2. ODVOZENÁ TŘÍDA 1: KritickyServer
// ============================================================================
class KritickyServer : public ServerNode {
public:
    KritickyServer(const string& nazev) : ServerNode(nazev) {}

    void diagnostika() override {
        cout << "[" << getNazev() << "]: Spustena kriticka bezpecnostni diagnostika jadra." << endl;
    }
};


// ============================================================================
// 3. ODVOZENÁ TŘÍDA 2: KlustrovyServer (BEZ VÝJIMEK)
// ============================================================================
class KlustrovyServer : public ServerNode {
public:
    KlustrovyServer(const string& nazev) : ServerNode(nazev) {}

    void diagnostika() override {
        cout << "[" << getNazev() << "]: Probiha synchronizace klustru." << endl;
    }
    
    // Přetížení operátoru + (ošetření chyby výpisem místo throw)
    KlustrovyServer operator+(const KlustrovyServer& druhy) const {
        // KONTROLA BEZ VÝJIMKY
        if (this->zatezCPU.size() != druhy.zatezCPU.size()) {
            cout << "CHYBA: Nelze spojit klustry s ruznym poctem mereni!" << endl;
            // Vrátíme prázdný objekt, aby program nespadl a mohl pokračovat
            return KlustrovyServer("Chyba_Spojeni"); 
        }

        KlustrovyServer vysledek(this->getNazev() + " + " + druhy.getNazev());

        for (size_t i = 0; i < this->zatezCPU.size(); ++i) {
            double prumer = (this->zatezCPU[i] + druhy.zatezCPU[i]) / 2.0;
            vysledek.pridejZaznam(prumer);
        }

        return vysledek;
    }
};


// ============================================================================
// 4. SAMOSTATNÉ ALGORITMY
// ============================================================================
void odstranDuplicity(vector<double>& zatez) {
    sort(zatez.begin(), zatez.end());
    zatez.erase(unique(zatez.begin(), zatez.end()), zatez.end());
}

int detekujSkokyZateze(const vector<double>& zatez, double hranice) {
    int pocetSkoku = 0;
    if (zatez.size() < 2) return 0;

    for (size_t i = 1; i < zatez.size(); i++) {
        double narust = zatez[i] - zatez[i - 1];
        if (narust > hranice) {
            cout << " -> Skok na indexu " << i << ": narust z " 
                 << zatez[i - 1] << "% na " << zatez[i] << "%" << endl;
            pocetSkoku++;
        }
    }
    return pocetSkoku;
}


